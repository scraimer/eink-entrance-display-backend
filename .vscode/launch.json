{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Server (inside devcontainer)",
            "type": "f5anything",
            "request": "launch",
            "command": "uvicorn src.eink_backend.main:app --reload --host 0.0.0.0 --port 8323"
        },
        {
            "name": "Python: Current File",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "env": {
                "PYTHONPATH": "${relativeFile}"
            },
            "console": "integratedTerminal"
        },
        {
            "name": "Python: chores.py as module",
            "type": "python",
            "request": "launch",
            "cwd": "${workspaceFolder}/src",
            "module": "eink_backend.chores",
            "console": "integratedTerminal"
        },
        {
            "name": "Python: Current File as module",
            "type": "python",
            "request": "launch",
            "cwd": "${workspaceFolder}/src",
            "module": "eink_backend.${fileBasenameNoExtension}",
            "console": "integratedTerminal"
        }
    ]
}